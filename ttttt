            <!-- Rozmiar cache — ustaw ~20-30% lokalnego dysku, nie NFS -->
            <maxCacheSize>20GB</maxCacheSize>

            <!-- Jak długo plik siedzi w cache bez użycia (ms) — 30 dni -->
            <maxAge>2592000000</maxAge>

            <!-- Katalog cache — LOKALNY dysk, nie NFS -->
            <cacheProviderDir>/var/opt/jfrog/artifactory/cache</cacheProviderDir>

